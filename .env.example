# Browser-visible API base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Choose and configure a model provider during implementation.
MODEL_PROVIDER=
MODEL_NAME=
MODEL_API_KEY=
EMBEDDING_MODEL=

# Deployment datastore; local tests must not require it.
DATABASE_URL=

# Hard safety and cost bounds
MAX_INPUT_BYTES=5000000
MAX_EXTRACTED_CHARACTERS=150000
ANALYSIS_TIMEOUT_SECONDS=120
MAX_ANALYSIS_COST_USD=1.00
